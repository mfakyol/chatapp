# =========================================================================
# chat-app — production environment
# Copy this file to ".env" and fill in the values, then:
#   docker compose -f docker-compose.prod.yml up -d --build
# TLS is terminated by your host nginx (see deploy/nginx-host.conf.example).
# =========================================================================

# ---- Public domain (used for CORS/Socket.io origin and the client bundle) ----
DOMAIN=chat.fatihakyol.com

# ---- Shared MongoDB (one mongo server for every project on this host) ----
# The database runs as the "shared-mongo" container on the external "shared"
# Docker network. This project has its own database + DB user inside it.
# Create the user once (as the mongo admin):
#   docker exec shared-mongo mongosh -u admin -p '<admin-pw>' --authenticationDatabase admin --eval \
#     'db.getSiblingDB("chat").createUser({user:"chat",pwd:"<db-pw>",roles:[{role:"readWrite",db:"chat"}]})'
MONGO_URI=mongodb://chat:<db-pw>@shared-mongo:27017/chat?authSource=chat

# ---- Auth (JWT) ----
# Tip: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
